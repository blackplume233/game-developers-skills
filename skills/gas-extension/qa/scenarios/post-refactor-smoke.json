{
  "name": "post-refactor-smoke",
  "description": "架构重构后冒烟测试：验证扩展激活、命令注册、Chat Provider 注册",
  "tags": ["smoke", "activation", "architecture-refactor"],
  "setup": {
    "build": true,
    "launchOptions": {}
  },
  "steps": [
    {
      "id": "startup",
      "description": "VS Code Insiders 以 Agents 模式启动并加载扩展",
      "action": "screenshot",
      "args": { "name": "01-startup" },
      "expect": "VS Code 正常启动，显示 Agents 欢迎页面，无崩溃弹窗或错误通知",
      "screenshotBefore": false,
      "screenshotAfter": true
    },
    {
      "id": "agents-sidebar-rendered",
      "description": "确认 Agents 模式侧边栏已渲染",
      "action": "hasText",
      "args": { "text": "Sessions" },
      "expect": "侧边栏包含 Sessions 标签，表明 Agents UI 已正常加载",
      "screenshotBefore": false,
      "screenshotAfter": false
    },
    {
      "id": "command-palette-opens",
      "description": "打开命令面板验证 VS Code 可交互",
      "action": "pressKey",
      "args": { "key": "F1" },
      "expect": "命令面板弹出",
      "screenshotBefore": false,
      "screenshotAfter": true
    },
    {
      "id": "close-palette",
      "description": "关闭命令面板",
      "action": "pressKey",
      "args": { "key": "Escape" },
      "expect": "命令面板关闭",
      "screenshotBefore": false,
      "screenshotAfter": false
    },
    {
      "id": "gas-audit-log-command",
      "description": "执行 GAS Show Audit Log 命令验证扩展激活",
      "action": "command",
      "args": { "label": "Game Agent Studio: Show Audit Log" },
      "expect": "命令成功执行，无报错通知。Output Channel 可能打开或在后台创建。",
      "screenshotBefore": false,
      "screenshotAfter": true
    },
    {
      "id": "no-activation-error",
      "description": "确认没有扩展激活错误通知",
      "action": "screenshot",
      "args": { "name": "04-no-error" },
      "expect": "屏幕上没有 'Activating extension failed' 或类似错误信息",
      "screenshotBefore": false,
      "screenshotAfter": true
    },
    {
      "id": "final-state",
      "description": "最终状态截图",
      "action": "screenshot",
      "args": { "name": "05-final" },
      "expect": "VS Code 处于正常状态",
      "screenshotBefore": false,
      "screenshotAfter": true
    }
  ],
  "cleanup": []
}
