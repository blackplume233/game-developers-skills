{
  "name": "chat-panel-interaction",
  "description": "验证 GAS Chat 面板的交互功能：打开、输入、Session 列表",
  "tags": ["chat", "ui", "interaction"],
  "setup": {
    "build": true,
    "launchOptions": {
      "readyTimeoutMs": 45000
    }
  },
  "steps": [
    {
      "id": "initial-state",
      "description": "Chat 面板初始状态截图",
      "action": "screenshot",
      "args": { "name": "chat-01-initial" },
      "expect": "Chat 面板在右侧可见，显示 'Build with Agent' 欢迎提示",
      "screenshotBefore": false,
      "screenshotAfter": false
    },
    {
      "id": "chat-welcome-text",
      "description": "检查欢迎文本",
      "action": "hasText",
      "args": { "text": "Build with Agent" },
      "expect": "Chat 面板中应显示 'Build with Agent' 欢迎信息",
      "screenshotBefore": false,
      "screenshotAfter": false
    },
    {
      "id": "open-chat-shortcut",
      "description": "通过快捷键聚焦 Chat 面板",
      "action": "pressKey",
      "args": { "key": "Control+Alt+I" },
      "expect": "Chat 输入框获得焦点，可以直接输入",
      "screenshotBefore": false,
      "screenshotAfter": true
    },
    {
      "id": "sessions-panel",
      "description": "检查 Sessions 面板",
      "action": "hasText",
      "args": { "text": "SESSIONS" },
      "expect": "Chat 右侧应有 SESSIONS 面板，显示 'New Session' 按钮",
      "screenshotBefore": false,
      "screenshotAfter": false
    },
    {
      "id": "new-session-button",
      "description": "New Session 按钮是否可见",
      "action": "hasText",
      "args": { "text": "New Session" },
      "expect": "New Session 按钮可见，允许创建新对话",
      "screenshotBefore": false,
      "screenshotAfter": true
    },
    {
      "id": "chat-input-area",
      "description": "验证 Chat 输入区域",
      "action": "queryText",
      "args": { "selector": "[placeholder*='Describe'], [placeholder*='build'], textarea" },
      "expect": "应有可用的输入区域（textarea 或 contenteditable）",
      "screenshotBefore": false,
      "screenshotAfter": false
    }
  ],
  "cleanup": []
}
